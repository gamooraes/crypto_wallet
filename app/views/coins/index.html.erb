<p style="color: green"><%= notice %></p>

<% content_for :title, "Coins" %>

<h1>Moedas</h1>
<div id="coins">
  <table>
    <thead>
      <tr>
        <th><%= @coins.human_attribute_name(:description)%></th>
        <th><%= @coins.human_attribute_name(:acronym)%></th>
        <th><%= @coins.human_attribute_name(:url_image)%></th>
        <th colspan="3"></th>
      </tr>    
    </thead>
    <tbody>
      <% @coins.each do |coin| %>
        <tr>
          <td><%= coin.description%></td>
          <td><%= coin.acronym %></td>
          <td><%= image_tag coin.url_image, size: "25x25" %></td>
          <td><%= link_to translated_navigation_links(:show), coin %></td>
          <td><%= link_to translated_navigation_links(:edit), edit_coin_path(coin) %></td>          
          <td><%= button_to translated_navigation_links(:delete), coin, method: :delete, form: { data: { turbo_confirm: 'Are you sure?' } } %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= link_to translated_navigation_links(:new_coin), new_coin_path %>
